# Production environment template
# Copy to .env.production for production-specific overrides

NODE_ENV=production
TZ=Asia/Jakarta
LOG_LEVEL=info
LOG_DIR=/home/container/data/log
LOG_NO_COLOR=false

DATABASE_URL=file:/home/container/data/bot.db

# Generate via: openssl rand -hex 32
AUTH_ENCRYPTION_KEY=replace-with-64-hex-chars

WA_ENABLED=true
OWNER_WA=
WA_RATE_MIN_TIME_MS=800

TELE_ENABLED=true
TELEGRAM_BOT_TOKEN=
OWNER_TG=
TELE_RATE_MIN_TIME_MS=50