{
  "name": "bot-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "format": "prettier --write \"*.{json,js,ts}\" \".prettierrc\" \"apps/**/*.{json,ts}\" \"packages/**/*.{json,ts}\"",
    "format:check": "prettier --check \"*.{json,js,ts}\" \".prettierrc\" \"apps/**/*.{json,ts}\" \"packages/**/*.{json,ts}\"",
    "start": "cross-env NODE_ENV=production npx prisma migrate deploy && cross-env NODE_ENV=production node apps/bot/dist/index.js",
    "start:wa": "cross-env NODE_ENV=production npx prisma migrate deploy && cross-env NODE_ENV=production node apps/wa/dist/index.js",
    "start:tele": "cross-env NODE_ENV=production npx prisma migrate deploy && cross-env NODE_ENV=production node apps/tele/dist/index.js",
    "dev": "cross-env NODE_ENV=development turbo run dev --filter=@app/bot",
    "dev:wa": "cross-env NODE_ENV=development turbo run dev --filter=@app/wa",
    "dev:tele": "cross-env NODE_ENV=development turbo run dev --filter=@app/tele",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2"
  }
}