# Node runtime
NODE_ENV=development

# Timezone for log timestamps, scheduler, and daily log rotation.
# IANA TZ name (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
# Indonesia: Asia/Jakarta (WIB) · Asia/Makassar (WITA) · Asia/Jayapura (WIT)
# Common:    UTC · Asia/Singapore · Asia/Tokyo · Europe/London · America/New_York
# Validated at boot via Intl.DateTimeFormat; invalid value falls back to Asia/Jakarta.
TZ=Asia/Jakarta

LOG_LEVEL=debug
LOG_DIR=./data/log
LOG_NO_COLOR=false
# Show full user IDs/JIDs in pretty terminal output. Default false (masked).
# Set true only for local debugging; never enable in shared production logs.
LOG_PII=true

# Database
DATABASE_URL=file:./data/bot.db

# Auth blob encryption (32-byte hex; generate via: openssl rand -hex 32 / node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_ENCRYPTION_KEY=replace-with-64-hex-chars

# WhatsApp adapter
WA_ENABLED=true
OWNER_WA=628987654321@s.whatsapp.net
WA_RATE_MIN_TIME_MS=800

# Telegram adapter
TELE_ENABLED=true
TELEGRAM_BOT_TOKEN=
OWNER_TG=
TELE_RATE_MIN_TIME_MS=50

# Owner ops (DANGEROUS)
# /eval evaluates JavaScript via node:vm. node:vm is NOT a security sandbox.
# Leave OWNER_EVAL_ENABLED unset/false unless this is a personal dev host
# AND every OWNER_WA/OWNER_TG identity is one you trust as much as the shell.
OWNER_EVAL_ENABLED=false

# Providers
COVENANT_API_KEY=your-covenant-api-key-here
PROVIDER_PRIMARY=siputzx
PROVIDER_FALLBACK=covenant
PROVIDER_HTTP_TIMEOUT_MS=15000
PROVIDER_RATE_MIN_TIME_MS=250
PROVIDER_MAX_CONCURRENT=4
PROVIDER_CIRCUIT_THRESHOLD=5
PROVIDER_CIRCUIT_COOLDOWN_MS=60000
PROVIDER_DOWNLOAD_MAX_BYTES=104857600
