# Development environment template
# Copy to .env.development for local-specific overrides

NODE_ENV=development
TZ=Asia/Jakarta
LOG_LEVEL=debug
LOG_DIR=./data/log
LOG_NO_COLOR=false

DATABASE_URL=file:./data/bot.db

# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_ENCRYPTION_KEY=replace-with-64-hex-chars

WA_ENABLED=true
OWNER_WA=
WA_RATE_MIN_TIME_MS=800

TELE_ENABLED=true
TELEGRAM_BOT_TOKEN=
OWNER_TG=
TELE_RATE_MIN_TIME_MS=50